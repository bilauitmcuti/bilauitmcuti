# Cloudflare Turnstile (anti-bot / spam)
# Public site key: set NEXT_PUBLIC_* in Pages build env, or TURNSTILE_SITE_KEY at runtime (via /api/turnstile/config).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
# TURNSTILE_SITE_KEY=your_turnstile_site_key_here
# Secret key must stay server-only
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Discord webhooks (server-only; do not commit real URLs)
# Star rating and feedback form submissions
DISCORD_WEBHOOK_RATE_FEEDBACK=https://discord.com/api/webhooks/your_rate_feedback_id/your_token
# Chat AI thumbs up / thumbs down
DISCORD_WEBHOOK_CHAT_HELPFUL=https://discord.com/api/webhooks/your_chat_helpful_id/your_token
DISCORD_WEBHOOK_CHAT_NOT_HELPFUL=https://discord.com/api/webhooks/your_chat_not_helpful_id/your_token

# Calendar API origin (server-only; browser uses /api/v1/meta and /api/v1/calendar). Default https://api.bilauitmcuti.com
# CALENDAR_API_BASE=https://api.bilauitmcuti.com

# Chat AI: Cloudflare Workers AI via Pages binding (variable name AI). No API key required.
# Configure in Cloudflare Dashboard: Pages → Settings → Bindings → Workers AI → name "AI".
# Local preview: pnpm run preview (uses wrangler pages dev --ai=AI).
# Default chat model (local + production): @cf/zai-org/glm-4.7-flash
# Fallback model: @cf/meta/llama-4-scout-17b-16e-instruct
# Optional overrides: AI_CHAT_MODEL=... (alias: WORKERS_AI_MODEL), AI_FALLBACK_MODEL=...
# Rollback example: AI_CHAT_MODEL=@cf/google/gemma-4-26b-a4b-it
# Chat agent (tool calling): CHAT_USE_AGENT=0 disables agent globally. GLM uses function calling on all hosts. See lib/chat/agent/run-agent.ts.
# CHAT_USE_AGENT=0

# AI Gateway (chat) — configured in wrangler.jsonc vars for production/preview deploys.
# Create gateway "bilauitmcuti-chat" in Cloudflare dashboard (AI → AI Gateway).
# AI_GATEWAY_ID=bilauitmcuti-chat
# SKIP_AI_GATEWAY=1
